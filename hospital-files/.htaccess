# Block all direct HTTP requests to this directory and its sub-directories.
# Files here are only reachable via PHP's filesystem API (path traversal
# through files.php is the intentional CTF vulnerability).
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
